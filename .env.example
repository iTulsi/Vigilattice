# Copy this file to .env and insert your real provider key.
# Never commit the real .env file.

VIGILATTICE_ENVIRONMENT=development
VIGILATTICE_LLM_API_KEY=
VIGILATTICE_LLM_BASE_URL=https://api.groq.com/openai/v1
VIGILATTICE_LLM_MODEL=openai/gpt-oss-20b
VIGILATTICE_LLM_TIMEOUT_SECONDS=30
VIGILATTICE_LLM_MAX_EVENTS=12
VIGILATTICE_LLM_MAX_OUTPUT_TOKENS=2400
